# Environment variables for the Expo app
EXPO_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Edge Functions - For sending emails
# You need to set this in Supabase Dashboard under Settings > Edge Functions
# RESEND_API_KEY should be set in Supabase Console for the send-email function
# Get your API key from https://resend.com/api-keys
